<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ThaloraBrowser.App"
             RequestedThemeVariant="Default">
    <!-- RequestedThemeVariant="Default" lets Avalonia follow the OS system theme
         (Light/Dark) via PlatformSettings.GetColorValues() on each platform. -->
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
