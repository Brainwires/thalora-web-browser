<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ThaloraBrowser.ViewModels"
        xmlns:controls="using:ThaloraBrowser.Controls"
        x:Class="ThaloraBrowser.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Thalora Browser"
        Width="1280" Height="800"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <!-- Tab strip button style -->
        <Style Selector="Button.tab-button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="CornerRadius" Value="6,6,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MaxWidth" Value="200"/>
        </Style>
        <Style Selector="Button.tab-button:pointerover">
            <Setter Property="Background" Value="#3D3D3D"/>
        </Style>
        <Style Selector="Button.tab-button-active">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="CornerRadius" Value="6,6,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MaxWidth" Value="200"/>
        </Style>

        <!-- Navigation button style -->
        <Style Selector="Button.nav-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.nav-button:pointerover">
            <Setter Property="Background" Value="#3D3D3D"/>
        </Style>
        <Style Selector="Button.nav-button:disabled">
            <Setter Property="Foreground" Value="#555555"/>
        </Style>

        <!-- Close tab button -->
        <Style Selector="Button.tab-close">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="16"/>
            <Setter Property="MinHeight" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.tab-close:pointerover">
            <Setter Property="Background" Value="#FF4444"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Tab Strip -->
        <Border DockPanel.Dock="Top" Background="#252525" Padding="4,4,4,0">
            <DockPanel>
                <!-- New Tab Button -->
                <Button DockPanel.Dock="Right"
                        Classes="nav-button"
                        Command="{Binding NewTabCommand}"
                        Content="+"
                        ToolTip.Tip="New Tab (Ctrl+T)"
                        Margin="4,0"/>

                <!-- Tab List -->
                <ItemsControl ItemsSource="{Binding Tabs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:BrowserTabViewModel">
                            <Button Classes.tab-button="{Binding !IsLoading}"
                                    Classes.tab-button-active="{Binding IsLoading}"
                                    x:Name="TabButton"
                                    Tag="{Binding}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <!-- Loading indicator or title -->
                                    <TextBlock Text="{Binding Title}"
                                               MaxWidth="150"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                    <Button Classes="tab-close"
                                            Content="x"
                                            Tag="{Binding}"
                                            ToolTip.Tip="Close Tab"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- Navigation Bar -->
        <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="6,4">
            <DockPanel>
                <!-- Navigation Buttons -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,6,0">
                    <Button Classes="nav-button"
                            Command="{Binding GoBackCommand}"
                            IsEnabled="{Binding CanGoBack}"
                            ToolTip.Tip="Back">
                        <TextBlock Text="&#x25C0;" FontSize="14"/>
                    </Button>
                    <Button Classes="nav-button"
                            Command="{Binding GoForwardCommand}"
                            IsEnabled="{Binding CanGoForward}"
                            ToolTip.Tip="Forward">
                        <TextBlock Text="&#x25B6;" FontSize="14"/>
                    </Button>
                    <Button Classes="nav-button"
                            Command="{Binding ReloadCommand}"
                            ToolTip.Tip="Reload">
                        <TextBlock Text="&#x21BB;" FontSize="16"/>
                    </Button>
                    <Button Classes="nav-button"
                            Command="{Binding GoHomeCommand}"
                            ToolTip.Tip="Home">
                        <TextBlock Text="&#x2302;" FontSize="16"/>
                    </Button>
                </StackPanel>

                <!-- Go Button -->
                <Button DockPanel.Dock="Right"
                        Classes="nav-button"
                        Command="{Binding NavigateCommand}"
                        ToolTip.Tip="Go"
                        Margin="4,0,0,0">
                    <TextBlock Text="&#x21B5;" FontSize="14"/>
                </Button>

                <!-- Address Bar -->
                <TextBox x:Name="AddressBar"
                         Text="{Binding AddressBarText, Mode=TwoWay}"
                         Watermark="Enter URL or search..."
                         FontSize="14"
                         Padding="8,4"
                         CornerRadius="4"
                         VerticalContentAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Loading indicator -->
        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsLoading}"
                     Height="2"
                     Foreground="#4488FF"
                     Background="Transparent"/>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#252525" Padding="8,3">
            <TextBlock Text="{Binding StatusBarText}"
                       FontSize="12"
                       Foreground="#888888"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <!-- Content Area -->
        <controls:WebContentControl x:Name="WebContent"
                                    HtmlContent="{Binding ActiveTab.HtmlContent}"
                                    BaseUrl="{Binding ActiveTab.Url}"
                                    Engine="{Binding ActiveTab.Engine}"/>
    </DockPanel>
</Window>
